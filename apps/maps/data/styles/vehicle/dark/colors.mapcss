@shop_label: #8E8882;
@industry_label: #7F858B;
@food_label: #A08B63;
@entertainment_label: #92877C;
@culture_label: #8C8378;
@hotel_label: #88827C;
@sport_label: #7F8784;
@nature_label: #7D8481;
@neutral_label: #7D8389;

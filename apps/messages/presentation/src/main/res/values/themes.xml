<resources>

    <attr name="bubbleColor" format="color|reference" />
    <attr name="switchThumbEnabled" format="color" />
    <attr name="switchThumbDisabled" format="color" />
    <attr name="switchTrackEnabled" format="color" />
    <attr name="switchTrackDisabled" format="color" />

    <style name="AppLaunchTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
    </style>

    <style name="AppTheme" parent="AppBaseTheme">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="AppBaseTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:divider">?attr/colorOutlineVariant</item>
        <item name="android:queryBackground">?attr/colorSurfaceContainerHigh</item>
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorTertiary">?attr/colorOutline</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="actionBarPopupTheme">@style/PopupTheme</item>
        <item name="bubbleColor">?attr/colorSurfaceContainerHigh</item>
        <item name="selectableItemBackground">@drawable/ripple</item>
        <item name="switchThumbEnabled">?attr/colorSurfaceContainerHighest</item>
        <item name="switchThumbDisabled">?attr/colorOutline</item>
        <item name="switchTrackEnabled">?attr/colorPrimaryContainer</item>
        <item name="switchTrackDisabled">?attr/colorSurfaceContainerHighest</item>
        <item name="windowActionBar">false</item>
    </style>

    <style name="AppThemeDialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorTertiary">?attr/colorOutline</item>
        <item name="android:windowBackground">?attr/colorSurfaceContainerHigh</item>
        <item name="actionBarPopupTheme">@style/PopupTheme</item>
        <item name="bubbleColor">?attr/colorSurfaceContainerHigh</item>
        <item name="selectableItemBackground">@drawable/ripple</item>
        <item name="windowActionBar">false</item>
    </style>

    <style name="PopupTheme" parent="ThemeOverlay.Material3.Light">
        <item name="android:colorBackground">?attr/colorSurfaceContainerHigh</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppTheme.Gallery" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:background">@color/black</item>
    </style>

    <!-- Black mode. No changes needed when not in night theme -->
    <style name="AppTheme.Black" />
    <style name="AppThemeDialog.Black" />
    <style name="PopupTheme.Black" />

</resources>

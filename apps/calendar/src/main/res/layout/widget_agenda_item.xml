<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widget_date_rail"
            android:layout_width="54dp"
            android:layout_height="58dp"
            android:background="@drawable/widget_date_rail"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_date_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:singleLine="true"
                android:textColor="#EDEDED"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_date_dow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:singleLine="true"
                android:textColor="#B8B8B8"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_card"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/widget_card_background"
            android:clipToOutline="true"
            android:gravity="center_vertical"
            android:outlineProvider="background"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_accent"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#2E8E70" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/widget_task_indicator"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/widget_task_indicator"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/widget_item_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:textColor="#F4F4F4"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/widget_item_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:textColor="#B8B8B8"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
